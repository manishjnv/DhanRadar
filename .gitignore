scripts/_deploy_tmp/

# ── OS / editor ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# ── Generated / runtime ───────────────────────────────────────────────
# claude-mem writes session memory context into AGENTS.md (regenerated each
# session). Local runtime artifact, not an instruction file — never commit it.
AGENTS.md

# private ops runbook — never in the public repo
docs/infra-notes.md

# local sample artifacts (CAS screenshots etc.) — public repo, may carry PII; never commit
docs/Sample/
_redact.py
*.tsbuildinfo
next-env.d.ts

# Personal Claude Code routing config (user-specific or.mjs path; do not commit)
.claude/settings.local.json
.claude/hooks/
# Local-only Claude skills — may hold proprietary methodology (e.g. the scoring
# engine). The repo is PUBLIC, so never push skill folders.
.claude/skills/
