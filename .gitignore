# ── Secrets / credentials — NEVER commit ──────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*credentials*.json
dhanradar*.json
secrets/
*.secret
backend/.keys/

# Local-only compose override (publishes ports, COOKIE_SECURE=False) —
# never deploy this; the committed compose has no host ports by design.
docker-compose.override.yml

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

