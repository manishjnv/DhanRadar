{
  "family": {
    "display": "'Manrope', ui-sans-serif, system-ui, -apple-system, sans-serif",
    "body": "'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif",
    "mono": "ui-monospace, 'SF Mono', 'JetBrains Mono', monospace"
  },
  "scale": {
    "display": {
      "size": "60px",
      "weight": 700,
      "letterSpacing": "-0.03em",
      "lineHeight": "1.05",
      "family": "display"
    },
    "h1": {
      "size": "44px",
      "weight": 700,
      "letterSpacing": "-0.025em",
      "lineHeight": "1.08",
      "family": "display"
    },
    "h2": {
      "size": "32px",
      "weight": 700,
      "letterSpacing": "-0.02em",
      "lineHeight": "1.15",
      "family": "display"
    },
    "h3": {
      "size": "22px",
      "weight": 600,
      "letterSpacing": "-0.015em",
      "lineHeight": "1.25",
      "family": "display"
    },
    "h4": {
      "size": "16px",
      "weight": 600,
      "letterSpacing": "-0.005em",
      "lineHeight": "1.4",
      "family": "body"
    },
    "body": {
      "size": "16px",
      "weight": 400,
      "lineHeight": "1.6",
      "family": "body"
    },
    "small": {
      "size": "14px",
      "weight": 400,
      "lineHeight": "1.5",
      "family": "body"
    },
    "caption": {
      "size": "12px",
      "weight": 500,
      "letterSpacing": "0.08em",
      "transform": "uppercase",
      "family": "body"
    }
  }
}