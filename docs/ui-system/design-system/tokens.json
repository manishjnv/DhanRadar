{
  "$schema": "DhanRadar Website Design Tokens v1.0",
  "brand": {
    "name": "DhanRadar",
    "tagline": "Your investment research assistant for smarter decisions.",
    "domain": "dhanradar.com"
  },
  "color": {
    "brand": {
      "deepNavy":     { "value": "#0B1F3A", "role": "Primary — trust anchor, headers, footer" },
      "electricBlue": { "value": "#2563EB", "role": "Action — CTAs, links, focus" },
      "emerald":      { "value": "#10B981", "role": "Positive — gains, Buy signals (light)" },
      "emeraldDark":  { "value": "#22D3A6", "role": "Positive — dark mode" }
    },
    "accent": {
      "cyan":  { "value": "#06B6D4", "role": "Info / highlight" },
      "amber": { "value": "#F59E0B", "role": "Warning / Hold / Caution" },
      "red":   { "value": "#EF4444", "role": "Negative / Avoid / Error" }
    },
    "semantic": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "error":   "#EF4444",
      "info":    "#2563EB"
    },
    "light": {
      "bg":              "#FFFFFF",
      "bgAlt":           "#F8FAFC",
      "surface":         "#FFFFFF",
      "surface2":        "#F1F5F9",
      "surface3":        "#E2E8F0",
      "border":          "#E5E7EB",
      "borderStrong":    "#CBD5E1",
      "text":            "#0F172A",
      "textSecondary":   "#334155",
      "textMuted":       "#64748B",
      "textFaint":       "#94A3B8"
    },
    "dark": {
      "bg":              "#020617",
      "bgAlt":           "#0F172A",
      "surface":         "#0F172A",
      "surface2":        "#1E293B",
      "surface3":        "#293548",
      "border":          "rgba(255,255,255,0.08)",
      "borderStrong":    "rgba(255,255,255,0.14)",
      "text":            "#F1F5F9",
      "textSecondary":   "#CBD5E1",
      "textMuted":       "#94A3B8",
      "textFaint":       "#64748B"
    }
  },
  "type": {
    "family": {
      "display": "'Manrope', ui-sans-serif, system-ui, -apple-system, sans-serif",
      "body":    "'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif",
      "mono":    "ui-monospace, 'SF Mono', 'JetBrains Mono', monospace"
    },
    "scale": {
      "display": { "size": "60px", "weight": 700, "letterSpacing": "-0.03em", "lineHeight": "1.05", "family": "display" },
      "h1":      { "size": "44px", "weight": 700, "letterSpacing": "-0.025em", "lineHeight": "1.08", "family": "display" },
      "h2":      { "size": "32px", "weight": 700, "letterSpacing": "-0.02em",  "lineHeight": "1.15", "family": "display" },
      "h3":      { "size": "22px", "weight": 600, "letterSpacing": "-0.015em", "lineHeight": "1.25", "family": "display" },
      "h4":      { "size": "16px", "weight": 600, "letterSpacing": "-0.005em", "lineHeight": "1.4",  "family": "body" },
      "body":    { "size": "16px", "weight": 400, "lineHeight": "1.6",  "family": "body" },
      "small":   { "size": "14px", "weight": 400, "lineHeight": "1.5",  "family": "body" },
      "caption": { "size": "12px", "weight": 500, "letterSpacing": "0.08em", "transform": "uppercase", "family": "body" }
    }
  },
  "spacing": {
    "0": "0px", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px",
    "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px",
    "20": "80px", "24": "96px", "32": "128px"
  },
  "radius":  { "none": "0", "sm": "6px", "md": "8px", "lg": "12px", "xl": "16px", "2xl": "20px", "full": "9999px" },
  "shadow": {
    "xs":  "0 1px 2px rgba(15,23,42,0.04)",
    "sm":  "0 1px 3px rgba(15,23,42,0.06), 0 1px 2px rgba(15,23,42,0.04)",
    "md":  "0 4px 12px rgba(15,23,42,0.06), 0 2px 4px rgba(15,23,42,0.04)",
    "lg":  "0 16px 40px -12px rgba(15,23,42,0.12)",
    "xl":  "0 28px 60px -20px rgba(15,23,42,0.18)",
    "ring": "0 0 0 3px rgba(37,99,235,0.16)"
  },
  "motion": {
    "fast":  "120ms cubic-bezier(0.4, 0, 0.2, 1)",
    "base":  "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "slow":  "320ms cubic-bezier(0.2, 0.7, 0.2, 1)",
    "stage": "560ms cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "breakpoint": {
    "sm":  "640px",
    "md":  "768px",
    "lg":  "1024px",
    "xl":  "1280px",
    "2xl": "1536px"
  },
  "zIndex": {
    "base":     1,
    "dropdown": 100,
    "sticky":   200,
    "drawer":   300,
    "modal":    400,
    "toast":    500
  },
  "signal": {
    "strongBuy": { "label": "Strong Buy", "min": 85, "color": "#10B981" },
    "buy":       { "label": "Buy",        "min": 70, "color": "#2563EB" },
    "hold":      { "label": "Hold",       "min": 55, "color": "#F59E0B" },
    "caution":   { "label": "Caution",    "min": 40, "color": "#F97316" },
    "avoid":     { "label": "Avoid",      "min": 0,  "color": "#EF4444" }
  }
}
