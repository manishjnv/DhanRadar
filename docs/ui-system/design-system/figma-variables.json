    {
      "name": "Radius",
      "modes": ["Default"],
      "variables": [
        { "name": "radius/sm",   "type": "FLOAT", "Default": 6 },
        { "name": "radius/md",   "type": "FLOAT", "Default": 8 },
        { "name": "radius/lg",   "type": "FLOAT", "Default": 12 },
