    },
    {
      "name": "Typography",
      "modes": ["Default"],
      "variables": [
        { "name": "font/display", "type": "STRING", "Default": "Manrope" },
        { "name": "font/body",    "type": "STRING", "Default": "Inter" },
        { "name": "font/mono",    "type": "STRING", "Default": "JetBrains Mono" },
        { "name": "size/display", "type": "FLOAT", "Default": 60 },
        { "name": "size/h1",      "type": "FLOAT", "Default": 44 },
        { "name": "size/h2",      "type": "FLOAT", "Default": 32 },
        { "name": "size/h3",      "type": "FLOAT", "Default": 22 },
        { "name": "size/h4",      "type": "FLOAT", "Default": 16 },
        { "name": "size/body",    "type": "FLOAT", "Default": 16 },
        { "name": "size/small",   "type": "FLOAT", "Default": 14 },
        { "name": "size/caption", "type": "FLOAT", "Default": 12 }
      ]
    },
    {
      "name": "Spacing",
      "modes": ["Default"],
      "variables": [
        { "name": "space/1",  "type": "FLOAT", "Default": 4 },
        { "name": "space/2",  "type": "FLOAT", "Default": 8 },
        { "name": "space/3",  "type": "FLOAT", "Default": 12 },
        { "name": "space/4",  "type": "FLOAT", "Default": 16 },
        { "name": "space/5",  "type": "FLOAT", "Default": 20 },
        { "name": "space/6",  "type": "FLOAT", "Default": 24 },
        { "name": "space/8",  "type": "FLOAT", "Default": 32 },
        { "name": "space/10", "type": "FLOAT", "Default": 40 },
        { "name": "space/12", "type": "FLOAT", "Default": 48 },
        { "name": "space/16", "type": "FLOAT", "Default": 64 }
