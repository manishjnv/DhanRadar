    {
      "name": "Breakpoint",
      "modes": ["Default"],
      "variables": [
        { "name": "bp/sm",  "type": "FLOAT", "Default": 640 },
        { "name": "bp/md",  "type": "FLOAT", "Default": 768 },
        { "name": "bp/lg",  "type": "FLOAT", "Default": 1024 },
        { "name": "bp/xl",  "type": "FLOAT", "Default": 1280 },
        { "name": "bp/2xl", "type": "FLOAT", "Default": 1536 }
      ]
    }
  ]
}
