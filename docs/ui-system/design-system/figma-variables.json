{
  "$comment": "DhanRadar — Figma Variables export (REST API shape). Import via a Figma variables plugin (e.g. 'Variables Import/Export'). Branding LOCKED — values mirror tokens.json. Two modes: Light, Dark.",
  "version": "1.0",
  "collections": [
    {
      "name": "Color",
      "modes": ["Light", "Dark"],
      "variables": [
        { "name": "brand/navy",         "type": "COLOR", "Light": "#0B1F3A", "Dark": "#0B1F3A" },
        { "name": "brand/blue",         "type": "COLOR", "Light": "#2563EB", "Dark": "#2563EB" },
        { "name": "brand/emerald",      "type": "COLOR", "Light": "#10B981", "Dark": "#22D3A6" },
        { "name": "accent/cyan",        "type": "COLOR", "Light": "#06B6D4", "Dark": "#06B6D4" },
        { "name": "accent/amber",       "type": "COLOR", "Light": "#F59E0B", "Dark": "#FBBF24" },
        { "name": "accent/red",         "type": "COLOR", "Light": "#EF4444", "Dark": "#F87171" },
        { "name": "semantic/success",   "type": "COLOR", "Light": "#10B981", "Dark": "#22D3A6" },
        { "name": "semantic/warning",   "type": "COLOR", "Light": "#F59E0B", "Dark": "#FBBF24" },
        { "name": "semantic/error",     "type": "COLOR", "Light": "#EF4444", "Dark": "#F87171" },
        { "name": "semantic/info",      "type": "COLOR", "Light": "#2563EB", "Dark": "#2563EB" },
        { "name": "bg/page",            "type": "COLOR", "Light": "#FFFFFF", "Dark": "#020617" },
        { "name": "bg/alt",             "type": "COLOR", "Light": "#F8FAFC", "Dark": "#0F172A" },
        { "name": "surface/1",          "type": "COLOR", "Light": "#FFFFFF", "Dark": "#0F172A" },
        { "name": "surface/2",          "type": "COLOR", "Light": "#F1F5F9", "Dark": "#1E293B" },
        { "name": "surface/3",          "type": "COLOR", "Light": "#E2E8F0", "Dark": "#293548" },
        { "name": "border/default",     "type": "COLOR", "Light": "#E5E7EB", "Dark": "#1E293B" },
        { "name": "border/strong",      "type": "COLOR", "Light": "#CBD5E1", "Dark": "#334155" },
        { "name": "text/primary",       "type": "COLOR", "Light": "#0F172A", "Dark": "#F1F5F9" },
        { "name": "text/secondary",     "type": "COLOR", "Light": "#334155", "Dark": "#CBD5E1" },
