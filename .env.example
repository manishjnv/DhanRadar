# =============================================================================
# DhanRadar — .env.example
#
# IMPORTANT: The real .env is gitignored and holds rotated R2 keys and all
# production secrets. NEVER commit the real .env to version control.
# Copy this file to .env and fill in real values for local dev or KVM4 deploy.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_HOST=dhanradar-postgres
POSTGRES_PORT=5432
# Owner / superuser role — used by Alembic migrations + owns every table & trigger.
POSTGRES_USER=dhanradar
POSTGRES_DB=dhanradar
POSTGRES_PASSWORD=changeme

# Least-privilege RUNTIME role the app + Celery connect as (B80), so the append-only trigger
# (I12) and RLS (I5) actually bind them. Migration 0051 creates the role; deploy.sh syncs this
# password onto it. If left blank, the app falls back to the owner role with a startup warning
# (no outage) — set it to a quote-free value to activate least-privilege. User defaults to
# dhanradar_app (override with DHANRADAR_APP_DB_USER).
DHANRADAR_APP_DB_PASSWORD=
# DHANRADAR_APP_DB_USER=dhanradar_app

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://dhanradar-redis:6379/0

# -----------------------------------------------------------------------------
# Cloudflare R2 (object storage)
# Keys are rotated; obtain from the Cloudflare dashboard.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=__set_in_real_env__
R2_ENDPOINT=https://__account_id__.r2.cloudflarestorage.com
R2_BUCKET=dhanradar-assets
R2_ACCESS_KEY_ID=__set_in_real_env__
R2_SECRET_ACCESS_KEY=__set_in_real_env__
# Backup destination for scripts/backup.sh / restore.sh / restore-drill.sh (B37).
# May equal R2_BUCKET (objects then live under the backups/ prefix); the R2
# lifecycle rule (≥7-yr retention, SEBI audit trail) must be scoped to that
# prefix (operator action; not yet set — see docs/ops/backup-restore-runbook.md).
R2_BACKUP_BUCKET=__set_in_real_env__

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=__set_in_real_env__
RESEND_API_KEY=__set_in_real_env__

# -----------------------------------------------------------------------------
# Kite Connect (Zerodha) — equities/ETF market-data provider, LATER PHASE
# Provider seam: Market Data Adapter equities/ETF ladder (upstox → kite → ...).
# NOT used by the MF-first launch wedge. NOT yet wired (provider is a stub).
# api_key/secret are static and live here; the daily access_token is obtained at
# runtime via the login-redirect exchange (NOT stored in .env). Market-data ONLY
# — never order placement (SEBI educational boundary). Exposing Kite-sourced
# quotes to non-Zerodha users needs a data-redistribution ToS clearance first.
# Tracked in BLOCKERS.md.
# -----------------------------------------------------------------------------
KITE_API_KEY=__set_in_real_env__
KITE_API_SECRET=__set_in_real_env__

# -----------------------------------------------------------------------------
# Observability (optional — leave blank to disable Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# JWT (RS256 asymmetric keypair)
# Generate dev keys with: python backend/scripts/gen_jwt_keys.py
# Then set these vars to the PEM file contents (multi-line values in .env
# must use literal \n or be set via export in shell for Docker Compose).
# NEVER commit real keys — backend/.keys/ and *.pem are gitignored.
# -----------------------------------------------------------------------------
# Two ways to supply the RS256 PEM (resolved by config.jwt_private_key /
# jwt_public_key). PREFERRED: *_FILE = path to a mounted PEM (keys never
# transit env; this is what docker-compose.override.yml uses for local test).
# Alternative: inline PEM with literal \n for single-line .env values.
JWT_PRIVATE_KEY=__run_gen_jwt_keys_py__
JWT_PUBLIC_KEY=__run_gen_jwt_keys_py__
JWT_PRIVATE_KEY_FILE=
JWT_PUBLIC_KEY_FILE=
JWT_ALGORITHM=RS256
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=7

# Set to False in local dev if not using HTTPS (e.g. plain http://localhost)
COOKIE_SECURE=True

# -----------------------------------------------------------------------------
# Razorpay
# Obtain from https://dashboard.razorpay.com/app/keys
# RAZORPAY_WEBHOOK_SECRET is set when configuring the webhook endpoint in the
# Razorpay dashboard.
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=__set_in_real_env__
RAZORPAY_KEY_SECRET=__set_in_real_env__
RAZORPAY_WEBHOOK_SECRET=__set_in_real_env__

# -----------------------------------------------------------------------------
# Runtime
# development | production
# -----------------------------------------------------------------------------
ENV=development

# -----------------------------------------------------------------------------
# DPDP consent gate (B48) — TEMPORARY pre-launch kill-switch
# Default true (gate ENFORCED). Set false ONLY in dev/test/ci to let consent-gated
# routes work before the consent-capture UI (B44) exists, while there is no real
# user data. Setting it false in any other ENV is a hard boot failure (fail-safe),
# so it cannot disable consent in production/staging. MUST be true (or removed)
# before the launch deploy.
# -----------------------------------------------------------------------------
DPDP_CONSENT_ENFORCED=true
