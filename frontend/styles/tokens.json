{
  "$schema": "DhanRadar Design Tokens v1.0",
  "brand": {
    "name": "DhanRadar",
    "tagline": "Investment intelligence for India",
    "domain": "dhanradar.com"
  },
  "color": {
    "brand": {
      "deepNavy":   { "value": "#0B1F3A", "role": "Primary — trust anchor" },
      "royalBlue":  { "value": "#1E5EFF", "role": "Action — CTAs, links" },
      "emerald":    { "value": "#00B386", "role": "Positive — light mode" },
      "emeraldDark":{ "value": "#1FD79A", "role": "Positive — dark mode" }
    },
    "accent": {
      "cyan":   { "value": "#00C2FF", "role": "Info, highlights" },
      "amber":  { "value": "#F5A623", "role": "Warning / attention state" },
      "red":    { "value": "#E5484D", "role": "Negative — light mode" },
      "redDark":{ "value": "#FF6166", "role": "Negative — dark mode" }
    },
    "light": {
      "bg":              "#F7F6F2",
      "bgElev":          "#FFFFFF",
      "surface":         "#FFFFFF",
      "surface2":        "#F1EFE9",
      "surface3":        "#E8E6DF",
      "border":          "#E4E1D9",
      "borderStrong":    "#D4D0C4",
      "text":            "#0B0F1A",
      "textSecondary":   "#3B414E",
      "textMuted":       "#6B7280",
      "textFaint":       "#9CA0AA"
    },
    "dark": {
      "bg":              "#07090F",
      "bgElev":          "#0B0F1A",
      "surface":         "#0E121E",
      "surface2":        "#141928",
      "surface3":        "#1B2133",
      "border":          "rgba(255,255,255,0.06)",
      "borderStrong":    "rgba(255,255,255,0.12)",
      "text":            "#ECEEF5",
      "textSecondary":   "#B9BFCF",
      "textMuted":       "#7E8699",
      "textFaint":       "#525868"
    }
  },
  "type": {
    "family": {
      "sans":   "var(--font-geist-sans), 'Geist', ui-sans-serif, system-ui, -apple-system, sans-serif",
      "mono":   "var(--font-geist-mono), 'Geist Mono', ui-monospace, 'SF Mono', monospace",
      "serif":  "var(--font-instrument-serif), 'Instrument Serif', Georgia, serif"
    },
    "scale": {
      "display": { "size": "64px", "weight": 500, "letterSpacing": "-0.035em", "lineHeight": "1.02" },
      "h1":      { "size": "40px", "weight": 500, "letterSpacing": "-0.025em", "lineHeight": "1.05" },
      "h2":      { "size": "28px", "weight": 500, "letterSpacing": "-0.02em",  "lineHeight": "1.15" },
      "h3":      { "size": "18px", "weight": 500, "letterSpacing": "-0.01em",  "lineHeight": "1.3"  },
      "body":    { "size": "15px", "weight": 400, "letterSpacing": "-0.005em", "lineHeight": "1.55" },
      "small":   { "size": "13px", "weight": 400, "letterSpacing": "-0.005em", "lineHeight": "1.45" },
      "caption": { "size": "11px", "weight": 500, "letterSpacing": "0.08em",   "lineHeight": "1.3",  "transform": "uppercase" }
    }
  },
  "spacing": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "6": "24px", "8": "32px", "12": "48px", "16": "64px" },
  "radius":  { "sm": "4px", "md": "8px", "lg": "12px", "xl": "14px", "2xl": "18px", "full": "999px" },
  "shadow": {
    "sm":  "0 1px 2px rgba(15,20,35,0.04)",
    "md":  "0 4px 16px rgba(15,20,35,0.06)",
    "lg":  "0 24px 60px -20px rgba(15,20,35,0.18)",
    "darkSm": "0 1px 2px rgba(0,0,0,0.4)",
    "darkMd": "0 8px 24px rgba(0,0,0,0.4)",
    "darkLg": "0 32px 80px -20px rgba(0,0,0,0.7)"
  },
  "label": {
    "_note": "Non-advisory educational labels (non-negotiable #2). Derived from the rule table, NOT numeric score thresholds. No buy/sell/hold verbs.",
    "in_form":           { "label": "In Form",           "color": "#00B386" },
    "on_track":          { "label": "On Track",          "color": "#00C2FF" },
    "off_track":         { "label": "Off Track",         "color": "#F5A623" },
    "out_of_form":       { "label": "Out of Form",       "color": "#E5484D" },
    "insufficient_data": { "label": "Insufficient Data", "color": "#6B7280" }
  }
}
