{
  "name": "dhanradar-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gen:api": "openapi-typescript ../contracts/openapi.yaml -o src/types/api.ts",
    "gen:tokens": "node scripts/gen-tokens.mjs",
    "check:tokens": "node scripts/gen-tokens.mjs --check",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-popover": "^1",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1",
    "@radix-ui/react-tabs": "^1",
    "@tanstack/react-query": "^5",
    "@tanstack/react-table": "^8",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "geist": "^1.7.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.17.0",
    "next": "14.2.29",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7",
    "react-markdown": "^10.1.0",
    "sonner": "^1",
    "tailwind-merge": "^2",
    "zod": "^3",
    "zustand": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1",
