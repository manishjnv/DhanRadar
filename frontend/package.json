    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2",
    "eslint-plugin-jsx-a11y": "^6",
    "jsdom": "^24",
    "msw": "^2",
    "openapi-typescript": "^7",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vitest": "^2"
  }
}
