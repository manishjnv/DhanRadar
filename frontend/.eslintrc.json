{
  "extends": [
    "next/core-web-vitals",
    "plugin:jsx-a11y/recommended"
  ],
  "plugins": ["jsx-a11y", "import", "boundaries"],
  "settings": {
    "boundaries/elements": [
      { "type": "feature", "mode": "folder", "pattern": "src/features/*", "capture": ["name"] },
      { "type": "shared", "mode": "full", "pattern": ["src/components/**", "src/lib/**", "src/hooks/**", "src/types/**", "src/styles/**"] },
      { "type": "app", "mode": "full", "pattern": "src/app/**" }
    ],
    "boundaries/ignore": ["**/*.test.*", "**/*.spec.*", "**/*.stories.*"]
  },
  "rules": {
    "boundaries/dependencies": [
      "error",
      {
        "default": "allow",
        "rules": [
          {
            "from": ["feature"],
            "disallow": [["feature", { "name": "!({{from.name}})" }]],
            "message": "Feature isolation: a feature must not import another feature's internals. Share code via src/components, src/lib, src/hooks, or src/types. (Enforced generically — every feature folder, including new ones, is covered automatically.)"
          }
        ]
      }
    ]
  }
}
